{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MathLoop",
  "version": "0.1.4",
  "identifier": "com.mathloop.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MathLoop",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../public/books",
      "../public/books.json"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
